<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
  xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
  xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
  x:Class="MauiExample.MainPage"
  x:Name="page"
>
  <ScrollView>
    <VerticalStackLayout Padding="30,0" Spacing="25">
      <Image
        Source="dotnet_bot.png"
        HeightRequest="185"
        Aspect="AspectFit"
        SemanticProperties.Description="dot net bot in a submarine number ten"
      />

      <Label
        Text="{Binding LastChanged, Source={x:Reference page}, StringFormat='Last written @ {0}'}"
        SemanticProperties.HeadingLevel="Level1"
        FontSize="32"
        HorizontalOptions="Center"
      />
      <Label
        Text="{Binding ApiKey, Source={x:Reference page}, StringFormat='Key is {0}'}"
        FontSize="18"
        FontAttributes="Bold"
        HorizontalOptions="Center"
      />
      <Button
        Text="Update key"
        FontAttributes="Bold"
        SemanticProperties.Hint="Updates stored ApiKey when you click"
        Clicked="OnClicked"
        HorizontalOptions="Center"
      />
    </VerticalStackLayout>
  </ScrollView>
</ContentPage>
